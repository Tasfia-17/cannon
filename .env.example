# ── TrueFoundry (required) ────────────────────────────────────────────────
# Create at: https://app.truefoundry.com → Settings → API Keys
TFY_API_KEY=your_truefoundry_pat_or_vat

# TrueFoundry AI Gateway base URL (SaaS default, no change needed)
TFY_AI_GATEWAY_URL=https://gateway.truefoundry.ai

# TrueFoundry MCP Gateway URL (your workspace URL)
# Found at: AI Gateway → MCP → your workspace URL
TFY_MCP_GATEWAY_URL=https://your-workspace.truefoundry.cloud

# ── AWS Bedrock models via TFY Gateway ───────────────────────────────────
# Configure AWS Bedrock provider in TFY UI first:
#   AI Gateway → Models → AWS Bedrock → add provider account "tfy-ai-bedrock"
CLAUDE_MODEL=tfy-ai-bedrock/anthropic.claude-3-5-sonnet-20241022-v2:0
LLAMA_MODEL=tfy-ai-bedrock/meta.llama3-3-70b-instruct-v1:0

# ── App config ────────────────────────────────────────────────────────────
MOCK_CLUSTER_URL=http://localhost:7100
CORS_ORIGINS=http://localhost:3000
